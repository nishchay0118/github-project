name: ci-cd pipeline

on:
  push:
    branches:
      - main

jobs:
  test:
    runs-on: ubuntu-latest

    steps:
      - name: checkout-code
        uses: actions/checkout@v4

      - name: setup-node
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: install-dependencies
        run: npm install

      - name: run-tests
        run: CI=true npm test

  build:
    runs-on: ubuntu-latest
    needs: test

    steps:
      - name: checkout-code
        uses: actions/checkout@v4

      - name: login-to-dockerhub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_TOcKEN }}

      - name: build-image
        run: docker build -t ${{ secrets.DOCKER_USERNAME }}/node-img:${{ github.sha }} .

      - name: push-image
        run: docker push ${{ secrets.DOCKER_USERNAME }}/node-img:${{ github.sha }}

      - name: deploy-to-ec2
        uses: appleboy/ssh-action@v1
        with:
          host: ${{ secrets.EC2_HOST }}
          username: ubuntu
          key: ${{ secrets.EC2_PEM_KEY }}
          script: |

            OLD_IMAGE=$(docker inspect node-app --format='{{.Config.Image}}' 2>/dev/null || true)

            echo "Old Image: $OLD_IMAGE"

            docker pull ${{ secrets.DOCKER_USERNAME }}/node-img:${{ github.sha }}

            docker stop node-app || true
            docker rm node-app || true

            docker run -d -p 3000:3000 \
              --name node-app \
              ${{ secrets.DOCKER_USERNAME }}/node-img:${{ github.sha }}

            sleep 10

            if curl -f http://localhost:3000/health; then
              echo "Deployment Successful"
            else
              echo "Deployment Failed"

              docker stop node-app || true
              docker rm node-app || true

              if [ ! -z "$OLD_IMAGE" ]; then
                echo "Rolling Back"

                docker run -d -p 3000:3000 \
                  --name node-app \
                  $OLD_IMAGE
              fi

              exit 1
            fi           
